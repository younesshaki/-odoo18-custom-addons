<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="cidmo_wizard_install_view_form" model="ir.ui.view">
            <field name="name">cidmo_wizard_install_view_form</field>
            <field name="model">cidmo.wizard.install</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="installation"/>
                            <label for="quantity"/>
                            <div class="o_row">
                                <field name="quantity"/>
                                <span>Unit(s)</span>
                            </div>
                            <field name="price_unit"/>

                        </group>
                    </sheet>

                    <footer class="oe_edit_only">
                        <button name="action_add_installation" string="Confirm" type="object" class="oe_highlight" data-hotkey="q"/>
                        <button string="Discard" special="cancel" data-hotkey="x"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>