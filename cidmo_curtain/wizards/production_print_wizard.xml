<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_production_print_wizard_form" model="ir.ui.view">
            <field name="name">production.print.wizard.form</field>
            <field name="model">production.print.wizard</field>
            <field name="arch" type="xml">
                <form string="Print Options">
                    <sheet>
                        <field name="lines_data" invisible="1"/>
                        <group>
                            <field name="production_sheet"/>
                            <field name="delivery_note"/>
                            <field name="product_label"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_validate" type="object" string="Validate"
                                class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>
