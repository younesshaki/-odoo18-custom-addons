<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="production_dailly_details_view_form" model="ir.ui.view">
            <field name="name">production_dailly_details_view_form</field>
            <field name="model">production.dailly.details</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_print_selected"
                                type="object"
                                string="Print"
                                class="oe_highlight"
                                invisible="is_form != True"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                            </group>
                            <group>
                                <button name="action_get_sale_orders" type="object"
                            string="Generate"
                            class="oe_highlight"
                            />
                            </group>

                            <field name="is_form" invisible="1"/>
                        </group>
                        <group>
                            <field name="sale_line_ids" create="0" delete="0" no_create="1" invisible="is_form != True">
                                <list editable="bottom" create="false">
                                    <field name="line_no" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="product_name" readonly="1"/>
                                    <field name="width" readonly="1"/>
                                    <field name="height" readonly="1"/>
                                    <field name="priority" readonly="1"/>
                                    <field name="state" readonly="1"/>
                                    <field name="sale_id" readonly="1"/>
                                </list>
                            </field>
                        </group>
                        <group>
                            <field name="production_line_ids" create="0" delete="0" no_create="1" invisible="is_form != True">
                                <list editable="bottom" create="false" decoration-danger="mrp_status == 'Not Started'"
                                      decoration-warning="mrp_status == 'In Works'"
                                      decoration-success="mrp_status == 'Complete'"
                                      decoration-info="mrp_status == 'Delivered'">
                                    <field name="is_selected" string=" "/>
                                    <field name="mrp_id_int" column_invisible="1"/>
                                    <field name="line_no" readonly="1"/>
                                    <field name="quantity" readonly="1"/>
                                    <field name="product_name" readonly="1"/>
                                    <field name="width" readonly="1"/>
                                    <field name="height" readonly="1"/>
                                    <field name="roll_width" readonly="1"/>
                                    <field name="orientation" readonly="1"/>
                                    <field name="priority" readonly="1"/>
                                    <field name="mrp_id" readonly="1"/>
                                    <field name="sale_id" readonly="1"/>
                                    <field name="mrp_status" readonly="1"/>
                                </list>
                            </field>
                        </group>
                    </sheet>

                </form>
            </field>
        </record>

        <record id="action_production_dailly_details" model="ir.actions.act_window">
            <field name="name">Production Dailly Details</field>
            <field name="res_model">production.dailly.details</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

        <menuitem id="menu_production_dailly_details" name="Production Dailly Details" parent="mrp.menu_mrp_root" action="action_production_dailly_details" sequence="11"/>
    </data>
</odoo>