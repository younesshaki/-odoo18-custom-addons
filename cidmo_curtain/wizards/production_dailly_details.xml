<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="production_dailly_details_view_form" model="ir.ui.view">
            <field name="name">production_dailly_details_view_form</field>
            <field name="model">production.dailly.details</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="date"/>
                            </group>
                            <group>
                                <button name="action_get_sale_orders" type="object"
                            string="Generate"
                            class="oe_highlight"
                            />
                            </group>

                            <field name="is_form" invisible="1"/>
                        </group>
                        <group>
                            <field name="sale_line_ids" readonly="1" invisible="is_form != True">
                                <list editable="bottom">
                                    <field name="line_no"/>
                                    <field name="quantity"/>
                                    <field name="product_name"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="priority"/>
                                    <field name="state"/>
                                    <field name="sale_id"/>
                                </list>
                            </field>
                        </group>
                        <group>
                            <field name="production_line_ids" readonly="1"  invisible="is_form != True">
                                <list editable="bottom">
                                    <field name="line_no"/>
                                    <field name="product_name"/>
                                    <field name="width"/>
                                    <field name="height"/>
                                    <field name="roll_width"/>
                                    <field name="priority"/>
                                    <field name="state"/>
                                    <field name="sale_id"/>
                                    <field name="mrp_id"/>
                                </list>
                            </field>
                        </group>
                    </sheet>

                </form>
            </field>
        </record>

        <record id="action_production_dailly_details" model="ir.actions.act_window">
            <field name="name">Production Dailly Details</field>
            <field name="res_model">production.dailly.details</field>
            <field name="view_mode">form</field>
            <field name="target">inline</field>
        </record>

        <menuitem id="menu_production_dailly_details" name="Production Dailly Details" parent="sale.sale_menu_root" action="action_production_dailly_details" sequence="11"/>
    </data>
</odoo>