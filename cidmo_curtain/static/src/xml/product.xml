<!--                    <label class="fw-bold text-break">Height</label>-->
<!--                </div>-->
<!--                <input class="o_input w-lg-75 mb-4 ms-lg-auto" type="text" placeholder="Enter a customized value"/>-->
<!--            </div>-->

<!--            <div name="ptal" class="d-flex">-->
<!--                <div class="d-flex flex-column flex-lg-row gap-2 mb-2">-->
<!--                    <label class="fw-bold text-break">Width</label>-->
<!--                </div>-->
<!--                <input class="o_input w-lg-75 mb-4 ms-lg-auto" type="text" placeholder="Enter a customized value"/>-->
<!--            </div>-->
        </xpath>
    </t>
</templates>


