<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="report_production_sheet" model="ir.actions.report">
            <field name="name">Production Sheet</field>
            <field name="model">production.print.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">cidmo_curtain.production_sheet_template</field>
            <field name="report_file">cidmo_curtain.production_sheet_template</field>
        </record>

        <record id="report_delivery_note" model="ir.actions.report">
            <field name="name">Delivery Note</field>
            <field name="model">production.print.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">cidmo_curtain.delivery_note_template</field>
            <field name="report_file">cidmo_curtain.delivery_note_template</field>
        </record>

        <record id="report_product_label" model="ir.actions.report">
            <field name="name">Product Label</field>
            <field name="model">production.print.wizard</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">cidmo_curtain.product_label_template</field>
            <field name="report_file">cidmo_curtain.product_label_template</field>
        </record>

        <!-- Production Sheet Template -->
        <template id="production_sheet_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="margin-bottom: 20px;">Production Sheet</h2>

                        <t t-if="not data.get('lines')">
                            <p class="text-danger">No production lines available.</p>
                        </t>
                        <t t-else="">
                            <table class="table table-bordered table-sm" style="font-size: 11pt;">
                                <thead>
                                    <tr>
                                        <th style="width: 5%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">#</th>
                                        <th style="width: 30%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Product</th>
                                        <th style="width: 10%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Width (m)</th>
                                        <th style="width: 10%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Height (m)</th>
                                        <th style="width: 10%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Qty</th>
                                        <th style="width: 15%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Priority</th>
                                        <th style="width: 20%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">MO Reference</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="data['lines']" t-as="line">
                                        <tr>
                                            <td t-esc="line_index + 1"/>
                                            <td t-esc="line.get('product_name', '')"/>
                                            <td t-esc="line.get('width', 0)"/>
                                            <td t-esc="line.get('height', 0)"/>
                                            <td t-esc="line.get('quantity', 0)"/>
                                            <td>
                                                <span t-if="line.get('priority') == 'express'"
                                                      style="background-color:#dc3545; color:#fff; padding: 2px 8px; border-radius: 3px;">
                                                    Express
                                                </span>
                                                <span t-else=""
                                                      style="background-color:#6c757d; color:#fff; padding: 2px 8px; border-radius: 3px;">
                                                    Standard
                                                </span>
                                            </td>
                                            <td t-esc="line.get('mrp_name', '')"/>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            <p style="margin-top: 10px; font-size: 9pt; color: #666;">
                                Total lines: <t t-esc="len(data['lines'])"/>
                            </p>
                        </t>
                    </div>
                </t>
            </t>
        </template>

        <!-- Delivery Note Template -->
        <template id="delivery_note_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="margin-bottom: 20px;">Delivery Note</h2>

                        <t t-if="not data.get('lines')">
                            <p class="text-danger">No delivery lines available.</p>
                        </t>
                        <t t-else="">
                            <table class="table table-bordered table-sm" style="font-size: 11pt;">
                                <thead>
                                    <tr>
                                        <th style="width: 5%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">#</th>
                                        <th style="width: 45%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Product</th>
                                        <th style="width: 25%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Sales Order</th>
                                        <th style="width: 15%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Qty</th>
                                        <th style="width: 10%; background-color: #343a40; color: #fff; -webkit-print-color-adjust: exact;">Priority</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="data['lines']" t-as="line">
                                        <tr>
                                            <td t-esc="line_index + 1"/>
                                            <td t-esc="line.get('product_name', '')"/>
                                            <td t-esc="line.get('sale_name', '')"/>
                                            <td t-esc="line.get('quantity', 0)"/>
                                            <td>
                                                <span t-if="line.get('priority') == 'express'"
                                                      style="background-color:#dc3545; color:#fff; padding: 2px 8px; border-radius: 3px;">
                                                    Express
                                                </span>
                                                <span t-else=""
                                                      style="background-color:#6c757d; color:#fff; padding: 2px 8px; border-radius: 3px;">
                                                    Standard
                                                </span>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                            <p style="margin-top: 10px; font-size: 9pt; color: #666;">
                                Total items: <t t-esc="len(data['lines'])"/>
                            </p>
                        </t>
                    </div>
                </t>
            </t>
        </template>

        <!-- Product Label Template -->
        <template id="product_label_template">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2 class="text-center" style="margin-bottom: 20px;">Product Labels</h2>

                        <t t-if="not data.get('lines')">
                            <p class="text-danger">No labels to print.</p>
                        </t>
                        <t t-else="">
                            <div class="row">
                                <t t-foreach="data['lines']" t-as="line">
                                    <div class="col-6" style="margin-bottom: 16px;">
                                        <div style="border: 2px solid #000; border-radius: 4px; padding: 14px; min-height: 110px;">
                                            <div style="font-size: 13pt; font-weight: bold; margin-bottom: 6px;">
                                                <t t-esc="line.get('product_name', '')"/>
                                            </div>
                                            <div style="font-size: 11pt; margin-bottom: 4px;">
                                                <strong>Dimensions:</strong>
                                                <t t-esc="line.get('width', 0)"/> m &#215;
                                                <t t-esc="line.get('height', 0)"/> m
                                            </div>
                                            <div style="font-size: 11pt; margin-bottom: 4px;">
                                                <strong>Qty:</strong> <t t-esc="line.get('quantity', 0)"/>
                                            </div>
                                            <t t-if="line.get('mrp_name')">
                                                <div style="font-size: 9pt; color: #555; margin-top: 6px; border-top: 1px solid #ccc; padding-top: 4px;">
                                                    MO: <t t-esc="line['mrp_name']"/>
                                                </div>
                                            </t>
                                            <t t-if="line.get('priority') == 'express'">
                                                <div style="font-size: 9pt; margin-top: 4px;">
                                                    <span style="background-color:#dc3545; color:#fff; padding: 2px 8px; border-radius: 3px;">
                                                        EXPRESS
                                                    </span>
                                                </div>
                                            </t>
                                        </div>
                                    </div>
                                </t>
                            </div>
                        </t>
                    </div>
                </t>
            </t>
        </template>
    </data>
</odoo>
