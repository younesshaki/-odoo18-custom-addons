<odoo>
    <record id="res_groups_privilege_product_configurator_mrp" model="res.groups.privilege">
        <field name="name">Product Configurator Manufacturing</field>
        <field name="category_id" ref="product_configurator.product_config_category" />
    </record>

    <record id="group_product_configurator_mrp" model="res.groups">
        <field name="name">Products &amp; BOMS</field>
        <field name="privilege_id" ref="res_groups_privilege_product_configurator_mrp" />
        <field
            eval="[(4, ref('product_configurator.group_product_configurator'))]"
            name="implied_ids"
        />
        <field eval="[(4, ref('base.user_root'))]" name="user_ids" />
    </record>
</odoo>
