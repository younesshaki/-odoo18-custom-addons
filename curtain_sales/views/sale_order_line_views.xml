<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_order_form_inherit_surface" model="ir.ui.view">
        <field name="name">sale.order.form.inherit.surface</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
        <!-- <xpath expr="//header" position="inside">
            <button name="action_create_mrp_orders" string="Create MRP Orders" type="object" class="btn-primary" invisible="state not in ('sale', 'done')"/>
        </xpath> -->
            <xpath expr="//field[@name='order_line']/tree//field[@name='product_uom_qty']" position="before">
                <field name="line_width" />
                <field name="line_length" />
                <field name="line_depth" />
                <field name="line_area" />
                <field name="line_volume" />
            </xpath>
            <xpath expr="//field[@name='partner_id']" position="after">
                <group>
                    <field name="priority_type"/>
                    <field name="lead_source"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>